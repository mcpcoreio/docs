{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MCPCore",
  "colors": {
    "primary": "#7c3aed",
    "light": "#a78bfa",
    "dark": "#6d28d9"
  },
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "mcpcore.io",
        "href": "https://mcpcore.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started free",
      "href": "https://app.mcpcore.io/register"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "MCP Servers",
            "pages": [
              "servers/create",
              "servers/settings",
              "servers/security-overview",
              {
                "group": "Security Modes",
                "pages": [
                  "servers/security/public",
                  "servers/security/api-key",
                  "servers/security/oauth2",
                  "servers/security/bearer-token"
                ]
              }
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "tools/create",
              "tools/sandbox",
              "tools/parameters",
              "tools/secrets",
              "tools/testing"
            ]
          },
          {
            "group": "Observability",
            "pages": [
              "observability/traffic-logs",
              "observability/error-logs",
              "observability/analytics"
            ]
          },
          {
            "group": "Connect AI Clients",
            "pages": [
              "connect/overview",
              "connect/claude-desktop",
              "connect/cursor",
              "connect/windsurf"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.mcpcore.io",
          "icon": "gauge"
        },
        {
          "anchor": "Blog",
          "href": "https://mcpcore.io/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mcpcore_io",
      "linkedin": "https://linkedin.com/company/mcpcore"
    }
  }
}
