{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MCPCore",
  "colors": {
    "primary": "#d2fa00",
    "light": "#e4fc66",
    "dark": "#a9c40d"
  },
  "css": "/custom.css",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://mcpcore.io"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Get started free",
      "href": "https://app.mcpcore.io/register"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "MCP Servers",
            "pages": [
              "servers/create",
              "servers/settings",
              "servers/security-overview",
              {
                "group": "Security Modes",
                "pages": [
                  "servers/security/public",
                  "servers/security/unlisted",
                  "servers/security/api-key",
                  "servers/security/oauth2"
                ]
              }
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "tools/create",
              "tools/sandbox",
              "tools/parameters",
              "tools/secrets",
              "tools/testing"
            ]
          },
          {
            "group": "Observability",
            "pages": [
              "observability/traffic-logs",
              "observability/error-logs",
              "observability/analytics"
            ]
          },
          {
            "group": "Connect AI Clients",
            "pages": [
              "connect/overview",
              "connect/claude-desktop",
              "connect/cursor",
              "connect/vscode",
              "connect/windsurf",
              "connect/cline"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.mcpcore.io",
          "icon": "gauge"
        },
        {
          "anchor": "Blog",
          "href": "https://mcpcore.io/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mcpcore",
      "linkedin": "https://linkedin.com/company/mcpcore",
      "instagram": "https://instagram.com/mcpcore"
    }
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#FFFFFF",
      "dark": "#000000"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "system"
  }
}
